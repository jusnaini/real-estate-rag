# ⚠️  IMPORTANT: No inline comments on the same line as a value!
#    WRONG:  GROQ_API_KEY=sk-... # my comment
#    RIGHT:  GROQ_API_KEY=sk-...
#    Inline comments become part of the value and cause auth errors.

# API Keys
OPENROUTER_API_KEY=
GROQ_API_KEY=
CEREBRAS_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=

# LLM Configuration
LLM_PROVIDER=groq
LLM_MODEL=openai/gpt-oss-120b

# Embedding Model
EMBEDDING_MODEL=all-MiniLM-L6-v2
RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# Chunking
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# Retrieval
TOP_K=5
RETRIEVER_TYPE=hybrid
EMBEDDING_BACKEND=onnx
